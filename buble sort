#include <stdio.h>
#include <stdlib.h>
#include <time.h>

#define N 15

void tampilkanArray(int arr[], int n) {
    printf("[");
    for (int i = 0; i < n; i++) {
        printf("%d", arr[i]);
        if (i < n - 1) printf(", ");
    }
    printf("]\n");
}

int main() {
    int data[N];
    int langkah = 0;

    srand((unsigned int) time(NULL));
    for (int i = 0; i < N; i++) {
        data[i] = rand() % 100 + 1;
    }

    printf("=== Array sebelum diurutkan ===\n");
    tampilkanArray(data, N);
    printf("\n=== Proses Bubble Sort ===\n");

    for (int batas = N - 1; batas > 0; batas--) {
        int adaPertukaran = 0;

        for (int i = 0; i < batas; i++) {
            if (data[i] > data[i + 1]) {
                
                int temp   = data[i];
                data[i]    = data[i + 1];
                data[i + 1] = temp;

                adaPertukaran = 1;
                langkah++;

                printf("Langkah %2d (tukar indeks %2d dan %2d): ", langkah, i, i + 1);
                tampilkanArray(data, N);
            }
        }

        if (adaPertukaran == 0) {
            break;
        }
    }

    printf("\n=== Array setelah diurutkan (ascending) ===\n");
    tampilkanArray(data, N);
    printf("\nTotal pertukaran yang terjadi: %d\n", langkah);

    return 0;
}
